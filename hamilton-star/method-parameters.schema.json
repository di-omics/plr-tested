{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/plr-tested/method-parameters.schema.json",
  "title": "Operator-approved sequencing method parameters",
  "type": "object",
  "additionalProperties": false,
  "anyOf": [
    { "required": ["wgs"] },
    { "required": ["pcr_enrichment"] },
    { "required": ["normalization"] },
    { "required": ["methylation_seq"] },
    { "required": ["scrnaseq"] }
  ],
  "properties": {
    "wgs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_volume_ul",
        "stage_1_volume_ul",
        "stage_2_volume_ul",
        "stage_3_volume_ul",
        "stage_4_volume_ul",
        "stage_5_volume_ul",
        "stage_6_volume_ul",
        "stage_7_volume_ul",
        "thermal_programs",
        "cleanup"
      ],
      "properties": {
        "input_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_1_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_2_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_3_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_4_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_5_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_6_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_7_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "thermal_programs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "preparation",
            "fragmentation",
            "end_repair",
            "ligation"
          ],
          "properties": {
            "preparation": { "type": "string", "minLength": 1 },
            "fragmentation": { "type": "string", "minLength": 1 },
            "end_repair": { "type": "string", "minLength": 1 },
            "ligation": { "type": "string", "minLength": 1 }
          }
        },
        "cleanup": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bead_volume_ul",
            "supernatant_remove_ul",
            "wash_add_ul",
            "wash_remove_ul",
            "residual_remove_ul",
            "elution_ul",
            "final_transfer_ul",
            "wash_count",
            "wash_incubation_seconds",
            "binding_handoff_id",
            "post_wash_handoff_id",
            "elution_handoff_id"
          ],
          "properties": {
            "bead_volume_ul": { "$ref": "#/$defs/positiveNumber" },
            "supernatant_remove_ul": { "$ref": "#/$defs/positiveNumber" },
            "wash_add_ul": { "$ref": "#/$defs/positiveNumber" },
            "wash_remove_ul": { "$ref": "#/$defs/positiveNumber" },
            "residual_remove_ul": { "$ref": "#/$defs/positiveNumber" },
            "elution_ul": { "$ref": "#/$defs/positiveNumber" },
            "final_transfer_ul": { "$ref": "#/$defs/positiveNumber" },
            "wash_count": {
              "type": "integer",
              "minimum": 1,
              "maximum": 2
            },
            "wash_incubation_seconds": { "$ref": "#/$defs/nonnegativeNumber" },
            "binding_handoff_id": { "type": "string", "minLength": 1 },
            "post_wash_handoff_id": { "type": "string", "minLength": 1 },
            "elution_handoff_id": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "pcr_enrichment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "round_1_transfer_ul",
        "round_2_transfer_ul",
        "sample_transfer_ul",
        "sample_blowout_ul",
        "round_1_reaction_volume_ul",
        "round_2_reaction_volume_ul",
        "round_2_input_volume_ul",
        "thermal_program_id",
        "cleanup"
      ],
      "properties": {
        "round_1_transfer_ul": { "$ref": "#/$defs/positiveNumber" },
        "round_2_transfer_ul": { "$ref": "#/$defs/positiveNumber" },
        "sample_transfer_ul": { "$ref": "#/$defs/positiveNumber" },
        "sample_blowout_ul": { "$ref": "#/$defs/positiveNumber" },
        "round_1_reaction_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "round_2_reaction_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "round_2_input_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "thermal_program_id": { "type": "string", "minLength": 1 },
        "cleanup": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bead_volume_ul",
            "supernatant_remove_ul",
            "wash_add_ul",
            "wash_remove_ul",
            "residual_remove_ul",
            "elution_ul",
            "bead_ratio",
            "input_volume_ul",
            "wash_count",
            "wash_incubation_seconds"
          ],
          "properties": {
            "bead_volume_ul": { "$ref": "#/$defs/positiveNumber" },
            "supernatant_remove_ul": { "$ref": "#/$defs/positiveNumber" },
            "wash_add_ul": { "$ref": "#/$defs/positiveNumber" },
            "wash_remove_ul": { "$ref": "#/$defs/positiveNumber" },
            "residual_remove_ul": { "$ref": "#/$defs/positiveNumber" },
            "elution_ul": { "$ref": "#/$defs/positiveNumber" },
            "bead_ratio": { "$ref": "#/$defs/positiveNumber" },
            "input_volume_ul": { "$ref": "#/$defs/positiveNumber" },
            "wash_count": {
              "type": "integer",
              "minimum": 1,
              "maximum": 2
            },
            "wash_incubation_seconds": { "$ref": "#/$defs/nonnegativeNumber" }
          }
        }
      }
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "excitation_nm",
        "emission_nm",
        "assay_dilution",
        "standard_concentrations_ng_per_ml",
        "standard_rfu"
      ],
      "properties": {
        "excitation_nm": { "$ref": "#/$defs/positiveNumber" },
        "emission_nm": { "$ref": "#/$defs/positiveNumber" },
        "assay_dilution": { "$ref": "#/$defs/positiveNumber" },
        "standard_concentrations_ng_per_ml": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/nonnegativeNumber" }
        },
        "standard_rfu": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/nonnegativeNumber" }
        }
      }
    },
    "methylation_seq": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_1_volume_ul",
        "stage_2_volume_ul",
        "stage_3_volume_ul",
        "stage_4_volume_ul",
        "stage_5_volume_ul",
        "stage_6_volume_ul",
        "stage_7_volume_ul",
        "stage_8_volume_ul",
        "stage_9_volume_ul",
        "stage_10_volume_ul",
        "stage_11_volume_ul",
        "cleanup"
      ],
      "properties": {
        "stage_1_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_2_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_3_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_4_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_5_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_6_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_7_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_8_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_9_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_10_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_11_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "cleanup": {
          "$ref": "#/$defs/threeCleanups"
        }
      }
    },
    "scrnaseq": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_1_volume_ul",
        "stage_2_volume_ul",
        "stage_3_volume_ul",
        "stage_4_volume_ul",
        "stage_5_volume_ul",
        "stage_6_volume_ul",
        "stage_7_volume_ul",
        "stage_8_volume_ul",
        "stage_9_volume_ul",
        "cleanup"
      ],
      "properties": {
        "stage_1_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_2_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_3_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_4_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_5_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_6_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_7_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_8_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "stage_9_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "cleanup": {
          "$ref": "#/$defs/threeCleanupsWithOptionalSecondRound"
        }
      }
    }
  },
  "$defs": {
    "positiveNumber": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "nonnegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ratio_label",
        "bead_volume_ul",
        "supernatant_remove_ul",
        "elution_ul",
        "keep_ul"
      ],
      "properties": {
        "ratio_label": { "type": "string", "minLength": 1 },
        "bead_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "supernatant_remove_ul": { "$ref": "#/$defs/positiveNumber" },
        "elution_ul": { "$ref": "#/$defs/positiveNumber" },
        "keep_ul": { "$ref": "#/$defs/positiveNumber" }
      }
    },
    "cleanupWithOptionalSecondStage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ratio_label",
        "stage_mode",
        "bead_volume_ul",
        "supernatant_remove_ul",
        "elution_ul",
        "keep_ul",
        "second_stage_add_ul",
        "second_stage_supernatant_remove_ul",
        "second_stage_elution_ul",
        "second_stage_keep_ul"
      ],
      "properties": {
        "ratio_label": { "type": "string", "minLength": 1 },
        "stage_mode": {
          "type": "string",
          "enum": ["single", "operator_defined_second_stage"]
        },
        "bead_volume_ul": { "$ref": "#/$defs/positiveNumber" },
        "supernatant_remove_ul": { "$ref": "#/$defs/positiveNumber" },
        "elution_ul": { "$ref": "#/$defs/positiveNumber" },
        "keep_ul": { "$ref": "#/$defs/positiveNumber" },
        "second_stage_add_ul": { "$ref": "#/$defs/nonnegativeNumber" },
        "second_stage_supernatant_remove_ul": { "$ref": "#/$defs/nonnegativeNumber" },
        "second_stage_elution_ul": { "$ref": "#/$defs/nonnegativeNumber" },
        "second_stage_keep_ul": { "$ref": "#/$defs/nonnegativeNumber" }
      }
    },
    "threeCleanups": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wash_add_ul",
        "wash_remove_ul",
        "residual_remove_ul",
        "cleanup_1",
        "cleanup_2",
        "cleanup_3"
      ],
      "properties": {
        "wash_add_ul": { "$ref": "#/$defs/positiveNumber" },
        "wash_remove_ul": { "$ref": "#/$defs/positiveNumber" },
        "residual_remove_ul": { "$ref": "#/$defs/positiveNumber" },
        "cleanup_1": { "$ref": "#/$defs/cleanup" },
        "cleanup_2": { "$ref": "#/$defs/cleanup" },
        "cleanup_3": { "$ref": "#/$defs/cleanup" }
      }
    },
    "threeCleanupsWithOptionalSecondRound": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wash_add_ul",
        "wash_remove_ul",
        "residual_remove_ul",
        "cleanup_1",
        "cleanup_2",
        "cleanup_3"
      ],
      "properties": {
        "wash_add_ul": { "$ref": "#/$defs/positiveNumber" },
        "wash_remove_ul": { "$ref": "#/$defs/positiveNumber" },
        "residual_remove_ul": { "$ref": "#/$defs/positiveNumber" },
        "cleanup_1": { "$ref": "#/$defs/cleanupWithOptionalSecondStage" },
        "cleanup_2": { "$ref": "#/$defs/cleanupWithOptionalSecondStage" },
        "cleanup_3": { "$ref": "#/$defs/cleanupWithOptionalSecondStage" }
      }
    }
  }
}
